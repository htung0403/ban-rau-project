# Zalo Notifications Configuration
# Copy these variables to your .env or deployment secrets

# === zca-js Personal Account Credentials ===
# Use ONE of the credential strategies below:
#
# 1) Put full credentials JSON in env
# ZCA_CREDENTIALS_JSON={"imei":"...","userAgent":"...","cookie":[...]}
#
# 2) Point to credentials file path
# ZCA_CREDENTIALS_PATH=./credentials/zca-credentials.json
# Optional path for generated QR image when running `pnpm zca:login`
ZCA_QR_PATH=./tmp/zca-qr.png
#
# 3) Set raw fields
# ZCA_COOKIE_JSON=[{"name":"...","value":"...","domain":"..."}]
# ZCA_IMEI=...
# ZCA_USER_AGENT=Mozilla/5.0 ...

# Optional language (default: vi)
ZCA_LANGUAGE=vi

# Optional manual mapping from phone -> Zalo UID to avoid findUser mismatch
# Example: {"0901234567":"1234567890123456789"}
ZCA_RECIPIENT_MAP_JSON={}

# Enable/disable Zalo sends (useful for testing)
# Set to 'true' to enable sends; anything else disables them
ZALO_ENABLE_SENDS=true

# === Optional: In-App Scheduler ===
# Only set to 'true' for single-worker deployments without external cron
# For scaled deployments, use external cron or cloud scheduler instead
ENABLE_IN_APP_CRON=false

# === Logging ===
# Zalo operations are logged to console and server logs
# For production, ensure logging is configured (CloudWatch, Sentry, etc.)
NODE_ENV=production

# === Security ===
# Protect internal trigger endpoints with authentication/token.
ADMIN_TOKEN=your_admin_api_token
